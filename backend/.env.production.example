# ═══════════════════════════════════════════════════════════════
# إعدادات الإنتاج - انسخ هذا الملف إلى .env وعدّل القيم
# ═══════════════════════════════════════════════════════════════

# Server Configuration
PORT=5000
NODE_ENV=production

# JWT Configuration (مطلوب - ولّد مفتاح جديد!)
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_A_SECURE_64_CHAR_KEY
JWT_EXPIRES_IN=7d

# Encryption Key (مطلوب - ولّد مفتاح جديد!)
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=CHANGE_THIS_TO_A_SECURE_32_CHAR_KEY

# Email Configuration (2FA)
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here

# CORS Configuration (غيّر للدومين الخاص بك)
CORS_ORIGIN=https://yourdomain.com

# SSL Configuration (مطلوب للإنتاج)
SSL_KEY_PATH=/path/to/private.key
SSL_CERT_PATH=/path/to/certificate.crt
