# Server Configuration
PORT=5000
NODE_ENV=development

# JWT Configuration
# ⚠️ يجب تغيير هذا المفتاح في الإنتاج لقيمة عشوائية قوية (32+ حرف)
# يمكنك توليد مفتاح آمن باستخدام: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_key_min_32_characters
JWT_EXPIRES_IN=7d

# Email Configuration (2FA)
# استخدم App Password من Google وليس كلمة المرور العادية
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here

# CORS Configuration
# في الإنتاج، حدد الدومين الخاص بك
CORS_ORIGIN=http://localhost:3000

# Encryption Key (للبيانات الحساسة)
# يمكنك توليد مفتاح آمن باستخدام: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your_encryption_key_min_32_characters

# SSL Configuration (اختياري للإنتاج)
# SSL_KEY_PATH=/path/to/private.key
# SSL_CERT_PATH=/path/to/certificate.crt
